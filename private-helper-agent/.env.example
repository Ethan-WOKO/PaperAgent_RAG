# Yanban Agent local development environment example
# Copy to .env locally if needed. Never commit real secrets.

# LLM providers
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GLM_API_KEY=your_glm_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# MCP
GITHUB_TOKEN=your_github_pat_here
YANBAN_MCP_GITHUB_ENABLED=false
YANBAN_MCP_GITHUB_COMMAND=cmd,/c,npx,-y,@modelcontextprotocol/server-github
YANBAN_MCP_GITHUB_ALLOWED_COMMANDS=cmd,npx,node
YANBAN_MCP_FILESYSTEM_ENABLED=false
YANBAN_MCP_FILESYSTEM_COMMAND=cmd,/c,npx,-y,@modelcontextprotocol/server-filesystem
YANBAN_MCP_FILESYSTEM_ALLOWED_COMMANDS=cmd,npx,node

# Security
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Infrastructure defaults
MYSQL_ROOT_PASSWORD=yanban_root_password
MYSQL_DATABASE=yanban_agent
MYSQL_USER=yanban
MYSQL_PASSWORD=yanban_password
REDIS_PASSWORD=yanban_redis_password
MINIO_ROOT_USER=yanbanminio
MINIO_ROOT_PASSWORD=yanban_minio_password
MINIO_BUCKET=yanban-agent
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
YANBAN_ES_ENDPOINT=http://localhost:9200
YANBAN_ES_INDEX=yanban-kb-chunks-v1
YANBAN_ES_VECTOR_DIMS=1024
YANBAN_EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
YANBAN_EMBEDDING_MODEL=text-embedding-v4
YANBAN_MINIO_ENDPOINT=http://localhost:9000
YANBAN_MINIO_BUCKET=yanban-agent
YANBAN_MINIO_SECURE=false
